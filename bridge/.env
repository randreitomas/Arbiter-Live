# ── Arbiter Bridge — environment variables ───────────────────────────────────
#
# 1. Register a Remote Agent on app.band.ai (e.g. name it "Arbiter Bridge")
# 2. Copy the Agent UUID and API Key shown after creation
# 3. Add the agent to your Arbiter adjudication room via Participants +
# 4. Fill in the values below, then: cp .env.example .env

# Band credentials for the bridge agent (separate from the other Arbiter agents)
THENVOI_AGENT_ID=03419cfe-79b9-4223-83ac-2027751d42e4
THENVOI_API_KEY=band_a_1781798850_oTKZURT1DDnY5ogCYU9KN9puIFK2A5Vu

# Room ID from your Band room URL: app.band.ai/chat/<ROOM_ID>
THENVOI_ROOM_ID=3fdd48b8-ccda-4b56-a813-dd4fbcb3ec0e

# HTTP + WebSocket server port (default 4000)
PORT=4000